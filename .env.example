# Copy to .env and edit. Do NOT commit .env (it's in .gitignore).
# install.sh sources this file before running.

# Where chaindata, configs, logs, and scripts live on the host.
DATADIR=/data/bsc-rpc

# BSC geth release tag to build. See https://github.com/bnb-chain/bsc/releases
GETH_VERSION=v1.7.3

# Public-facing nginx ports for the bot to hit (X-API-Key gated).
RPC_HTTP_PORT=8645
RPC_WS_PORT=8646

# BSC peer-to-peer port (must be open on the host firewall).
P2P_PORT=30311

# Geth in-process cache, MiB. Rule of thumb: ~75% of RAM for an RPC node.
# 49152 = 48 GiB on a 64 GB box.
GETH_CACHE_MB=49152

# txpool sizing. Default BSC values (8000 / 4000) are too small for a sniping
# mempool. We bump to keep more pending txs visible.
TXPOOL_GLOBAL_SLOTS=100000
TXPOOL_GLOBAL_QUEUE=50000

# 64-hex API key the bot must send as X-API-Key header. Leave empty and
# install.sh will generate one with `openssl rand -hex 32`.
API_KEY=

# Disk monitor threshold (percent). Logs warning + writes to disk-alerts.log
# when /data exceeds this.
DISK_ALERT_THRESHOLD=80

# Optional: SSH source-IP allowlist (space-separated CIDRs). If set, install.sh
# will only allow port 22 from these. Leave empty for "any".
SSH_ALLOW_FROM=

# Optional: bot source-IP allowlist for the RPC ports. If set, install.sh will
# only allow ${RPC_HTTP_PORT}/${RPC_WS_PORT} from these IPs (defense in depth
# on top of the API key).
BOT_ALLOW_FROM=
